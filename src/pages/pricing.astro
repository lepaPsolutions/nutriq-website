---
import BaseLayout from "../layouts/BaseLayout.astro";
import PricingMatrix from "../components/pricing/PricingMatrix.astro";
import FAQ from "../components/home/FAQ.astro";
import FinalCTA from "../components/home/FinalCTA.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={lang === "el" ? "Τιμές — Nutriq" : "Pricing — Nutriq"}
  description={lang === "el"
    ? "Διαφανείς τιμές για διαιτολόγους. SOLO από 19€/μήνα. TEAM από 119€/μήνα. Όλα τα πλάνα με 14 ημέρες δωρεάν."
    : "Transparent pricing for dietitians. SOLO from €19/mo. TEAM from €119/mo. All plans include 14 days free."}
>
  <!-- Page hero -->
  <section class="relative pt-20 md:pt-24 pb-6 overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-aurora opacity-80" aria-hidden="true"></div>
    <div class="absolute inset-0 -z-10 bg-grid opacity-30" aria-hidden="true"></div>
    <div class="container-x text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/80 backdrop-blur-md border border-gray-200 px-4 py-1.5 shadow-xs">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        <span class="text-[12px] font-semibold tracking-[0.04em] uppercase text-gray-700">{t("nav.pricing")}</span>
      </div>
      <h1 class="mt-7 text-display-lg text-ink text-balance max-w-4xl mx-auto">
        {t("pricing.title")}
      </h1>
      <p class="mt-6 max-w-xl mx-auto text-[18px] leading-[1.55] text-gray-600 text-pretty">
        {t("pricing.subtitle")}
      </p>
    </div>
  </section>

  <PricingMatrix />

  <FAQ />
  <FinalCTA />
</BaseLayout>
