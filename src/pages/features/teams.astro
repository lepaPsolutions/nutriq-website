---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SimpleFeaturePage from "../../components/SimpleFeaturePage.astro";
import FinalCTA from "../../components/home/FinalCTA.astro";
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const content = lang === "el"
  ? {
      eyebrow: "Διαχείριση Ομάδας",
      title: "Ένα κέντρο. Πολλοί διαιτολόγοι. Μηδέν χάος.",
      sub: "Διαχειρίσου την ομάδα σου, το πελατολόγιο, και τους πόρους του κέντρου από ένα κεντρικό dashboard. Ξεχωριστές άδειες, κοινά templates, συγκεντρωτικά analytics.",
      bullets: [
        { title: "Ρόλοι & άδειες", body: "Professional Admin (κέντρου) και Διαιτολόγοι (μέλη). Κάθε ρόλος βλέπει μόνο όσα του αναλογούν." },
        { title: "Ξεχωριστό πελατολόγιο", body: "Κάθε διαιτολόγος βλέπει μόνο τους δικούς του πελάτες. Ο admin έχει πρόσβαση σε όλους." },
        { title: "Μεταφορά πελατών", body: "Όταν φύγει διαιτολόγος, οι πελάτες του ανατίθενται σε άλλο μέλος με ένα κλικ. Ιστορικό διατηρείται." },
        { title: "Κοινά templates", body: "Όλα τα templates και πλάνα του κέντρου διαθέσιμα σε όλη την ομάδα. Δουλέψτε επιστημονικά, όχι ατομικιστικά." },
        { title: "Team analytics", body: "Στατιστικά απόδοσης ανά διαιτολόγο: ενεργοί πελάτες, συνεδρίες, αποτελέσματα. Διαφανές για admin." },
        { title: "Email προσκλήσεις", body: "Πρόσκληση μέλους με ένα email. Σύνδεση μέσω secure invitation code. Ακύρωση/αλλαγή ρόλου ανά πάσα στιγμή." },
      ],
      closingHeading: "Σχεδιασμένη για κέντρα 2-50 ατόμων.",
      closingBody: "Όσο μεγαλώνει το κέντρο σου, τόσο σημαντικότερη γίνεται η συντονισμένη δουλειά. Η Nutriq κάνει την κλιμάκωση σου εύκολη — από 2 σε 20 διαιτολόγους χωρίς πονοκέφαλο.",
    }
  : {
      eyebrow: "Team Management",
      title: "One center. Many dietitians. Zero chaos.",
      sub: "Manage your team, caseload, and center resources from one central dashboard. Distinct permissions, shared templates, aggregated analytics.",
      bullets: [
        { title: "Roles & permissions", body: "Professional Admin (center owner) and Dietitians (members). Each role sees only what they should." },
        { title: "Separate caseloads", body: "Each dietitian sees only their own clients. The admin has access to all." },
        { title: "Client reassignment", body: "When a dietitian leaves, their clients can be reassigned to another member in one click. History preserved." },
        { title: "Shared templates", body: "All center templates and plans available across the team. Work scientifically, not in silos." },
        { title: "Team analytics", body: "Performance metrics per dietitian: active clients, sessions, outcomes. Transparent for admins." },
        { title: "Email invitations", body: "Invite a member with one email. Onboarding via secure invitation code. Revoke or change role anytime." },
      ],
      closingHeading: "Designed for centers of 2 to 50 people.",
      closingBody: "As your center grows, coordinated work becomes more critical. Nutriq makes scaling easy — from 2 to 20 dietitians without the headache.",
    };
---

<BaseLayout
  title={lang === "el" ? "Διαχείριση Ομάδας — Nutriq" : "Team Management — Nutriq"}
  description={content.sub}
>
  <SimpleFeaturePage {...content} />
  <FinalCTA />
</BaseLayout>
