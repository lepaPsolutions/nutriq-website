---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalPage from "../components/LegalPage.astro";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const content = lang === "el"
  ? {
      eyebrow: "Νομικά",
      title: "Όροι Χρήσης",
      lastUpdated: "Τελευταία ενημέρωση: Μάιος 2026",
      intro: "Καλώς ήρθατε στη Nutriq. Με τη χρήση της πλατφόρμας μας, αποδέχεστε τους παρόντες όρους. Διαβάστε τους προσεκτικά.",
      sections: [
        { heading: "Αποδοχή των όρων", body: "Δημιουργώντας λογαριασμό στη Nutriq, αποδέχεστε αυτούς τους Όρους και την Πολιτική Απορρήτου μας. Εάν δεν συμφωνείτε, μη χρησιμοποιήσετε την υπηρεσία." },
        { heading: "Λογαριασμός & πρόσβαση", body: "Είστε υπεύθυνοι για την ασφάλεια του λογαριασμού σας και για όλες τις ενέργειες που γίνονται μέσω αυτού. Πρέπει να ειδοποιήσετε άμεσα σε περίπτωση παραβίασης. Δεν διαμοιράζετε credentials." },
        { heading: "Επιτρεπόμενη χρήση", body: "Η Nutriq προορίζεται για επαγγελματική χρήση από διαιτολόγους/διατροφολόγους και διαιτολογικά κέντρα. Δεν μπορείτε να χρησιμοποιήσετε την υπηρεσία για παράνομες ή απαγορευμένες δραστηριότητες, να αναπτύξετε ανταγωνιστικό προϊόν, ή να εξαντλήσετε πόρους κακόβουλα." },
        { heading: "Δεδομένα πελατών σας", body: "Είστε ο controller των δεδομένων που εισάγετε για τους δικούς σας πελάτες. Εμείς είμαστε ο processor. Πρέπει να έχετε νόμιμη βάση επεξεργασίας (συναίνεση πελάτη) και να συμμορφώνεστε με GDPR/HIPAA σύμφωνα με τη δικαιοδοσία σας." },
        { heading: "Συνδρομές & πληρωμές", body: "Οι συνδρομές χρεώνονται μηνιαία ή ετήσια. Δωρεάν δοκιμή 14 ημερών χωρίς υποχρέωση. Ακύρωση ανά πάσα στιγμή μέσα από το dashboard. Δεν επιστρέφονται χρήματα για ήδη πληρωμένη περίοδο." },
        { heading: "AI Credits", body: "Τα AI Credits περιλαμβάνονται στη συνδρομή ή αγοράζονται σε πακέτα. Δε λήγουν εντός της ενεργής συνδρομής. Σε ακύρωση, χάνονται. Δεν επιστρέφονται." },
        { heading: "Ευθύνη", body: "Η Nutriq είναι εργαλείο υποστήριξης. ΔΕΝ αντικαθιστούμε την επαγγελματική κρίση. Η ευθύνη για τις διατροφικές οδηγίες που δίνετε σε πελάτες παραμένει αποκλειστικά δική σας. Δε φέρουμε ευθύνη για ζημιές που προκύπτουν από διατροφικές αποφάσεις." },
        { heading: "Ακύρωση & τερματισμός", body: "Μπορούμε να αναστείλουμε λογαριασμό για παραβίαση των όρων, μη πληρωμή, ή κακόβουλη χρήση. Μετά την ακύρωση, έχετε 90 ημέρες grace period για export δεδομένων." },
        { heading: "Εφαρμοστέο δίκαιο", body: "Οι παρόντες όροι διέπονται από το Ελληνικό δίκαιο. Δικαιοδοσία έχουν τα δικαστήρια Αθηνών." },
      ],
    }
  : {
      eyebrow: "Legal",
      title: "Terms of Service",
      lastUpdated: "Last updated: May 2026",
      intro: "Welcome to Nutriq. By using our platform, you accept these terms. Please read them carefully.",
      sections: [
        { heading: "Acceptance of terms", body: "By creating a Nutriq account, you accept these Terms and our Privacy Policy. If you don't agree, don't use the service." },
        { heading: "Account & access", body: "You are responsible for the security of your account and for all activity that occurs under it. You must notify us immediately of any breach. Don't share credentials." },
        { heading: "Permitted use", body: "Nutriq is intended for professional use by dietitians/nutritionists and nutrition centers. You may not use the service for illegal or prohibited activities, develop a competing product, or maliciously exhaust resources." },
        { heading: "Your client data", body: "You are the controller of data you enter for your own clients. We are the processor. You must have a legal basis for processing (client consent) and comply with GDPR/HIPAA per your jurisdiction." },
        { heading: "Subscriptions & payments", body: "Subscriptions billed monthly or annually. 14-day free trial, no obligation. Cancel anytime from the dashboard. No refunds for already-paid periods." },
        { heading: "AI Credits", body: "AI Credits are included in your subscription or purchased in packs. They don't expire during active subscription. Lost upon cancellation. Non-refundable." },
        { heading: "Liability", body: "Nutriq is a support tool. We do NOT replace professional judgment. Responsibility for nutritional guidance given to clients remains solely yours. We are not liable for damages from nutrition decisions." },
        { heading: "Cancellation & termination", body: "We may suspend an account for terms violation, non-payment, or malicious use. After cancellation, you have a 90-day grace period for data export." },
        { heading: "Governing law", body: "These terms are governed by Greek law. Jurisdiction: Athens courts." },
      ],
    };
---

<BaseLayout title={lang === "el" ? "Όροι Χρήσης — Nutriq" : "Terms of Service — Nutriq"} description={content.intro}>
  <LegalPage {...content} />
</BaseLayout>
