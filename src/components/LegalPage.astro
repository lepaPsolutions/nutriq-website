---
interface Section {
  heading: string;
  body: string;
}

interface Props {
  eyebrow: string;
  title: string;
  lastUpdated: string;
  intro: string;
  sections: Section[];
}

const { eyebrow, title, lastUpdated, intro, sections } = Astro.props;
---

<section class="relative pt-20 md:pt-24 pb-12 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-aurora opacity-60" aria-hidden="true"></div>
  <div class="container-x">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/80 backdrop-blur-md border border-gray-200 px-4 py-1.5 shadow-xs">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        <span class="text-[12px] font-semibold tracking-[0.04em] uppercase text-gray-700">{eyebrow}</span>
      </div>
      <h1 class="mt-7 text-display-md text-ink text-balance">{title}</h1>
      <p class="mt-5 text-[13px] text-gray-500">{lastUpdated}</p>
    </div>
  </div>
</section>

<section class="pb-24">
  <div class="container-x">
    <div class="max-w-3xl mx-auto">
      <p class="text-[17px] leading-[1.7] text-gray-700 text-pretty">{intro}</p>

      <div class="mt-12 space-y-10">
        {sections.map((s, i) => (
          <div>
            <h2 class="text-[22px] font-bold tracking-[-0.02em] text-ink">
              <span class="text-brand-700 tabular-nums mr-2">{String(i + 1).padStart(2, "0")}.</span>
              {s.heading}
            </h2>
            <p class="mt-4 text-[16px] leading-[1.7] text-gray-700 text-pretty whitespace-pre-line">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
