---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { num: t("problem.stat-1-num"), label: t("problem.stat-1-label") },
  { num: t("problem.stat-2-num"), label: t("problem.stat-2-label") },
  { num: t("problem.stat-3-num"), label: t("problem.stat-3-label") },
];
---

<section class="section bg-cream-100">
  <div class="container-x">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-5">
        <p class="overline">{t("problem.eyebrow")}</p>
        <h2 class="mt-5 text-display-md text-ink text-balance">
          {t("problem.title")}
        </h2>
      </div>
      <div class="lg:col-span-6 lg:col-start-7">
        <p class="text-[18px] leading-[1.6] text-gray-600 text-pretty">
          {t("problem.subtitle")}
        </p>
      </div>
    </div>

    <!-- Stats row — modern SaaS clean -->
    <div class="mt-16 md:mt-20 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-4">
      {stats.map((stat, i) => (
        <div class={`relative pt-8 ${i > 0 ? "md:border-l md:border-gray-300 md:pl-8 lg:pl-12" : ""}`}>
          <p class="text-[clamp(2.5rem,6vw,4rem)] font-bold leading-none tracking-tighter text-brand-800 tabular-nums">
            {stat.num}
          </p>
          <p class="mt-3 text-[15px] text-gray-600 max-w-xs leading-snug">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
