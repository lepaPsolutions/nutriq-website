---
import { getLangFromUrl, useTranslations, localizePath } from "../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Highlight one word inside title-2 with brush underline
const headline2 = t("hero.title-2");
---

<section class="relative pt-12 md:pt-16 pb-24 md:pb-32 overflow-hidden">
  <!-- Animated aurora background -->
  <div class="absolute inset-0 -z-10 bg-aurora" aria-hidden="true"></div>
  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 -z-10 bg-grid opacity-40" aria-hidden="true"></div>
  <!-- Vignette at top -->
  <div class="absolute inset-x-0 top-0 -z-10 h-32 bg-gradient-to-b from-white to-transparent" aria-hidden="true"></div>

  <div class="container-x">
    <!-- Live ticker chip -->
    <div class="flex justify-center animate-fade-in">
      <div class="inline-flex items-center gap-2.5 rounded-full bg-white/80 backdrop-blur-md border border-gray-200 px-4 py-1.5 shadow-xs">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-brand-400 animate-pulse-ring"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500"></span>
        </span>
        <span class="text-[12px] font-semibold tracking-[0.02em] text-gray-700">
          {lang === "el" ? "Live · " : "Live · "}
          <span id="live-counter" class="tabular-nums font-bold text-brand-700">2,341</span>
          {lang === "el" ? " πλάνα παράγονται σήμερα" : " plans generated today"}
        </span>
      </div>
    </div>

    <!-- Headline -->
    <h1 class="mt-7 text-display-xl text-ink text-balance text-center max-w-5xl mx-auto">
      <span class="block animate-fade-up" style="--i:1; animation-delay:.05s">
        {t("hero.title-1")} <span class="underline-brush text-brand-900">{headline2}</span>
      </span>
      <span class="block text-gray-400 mt-1 animate-fade-up" style="--i:2; animation-delay:.18s">
        {t("hero.title-3")}
      </span>
    </h1>

    <p class="mt-7 max-w-2xl mx-auto text-[18px] leading-[1.55] text-gray-600 text-pretty text-center animate-fade-up" style="--i:3; animation-delay:.32s">
      {t("hero.subtitle")}
    </p>

    <div class="mt-9 flex flex-wrap justify-center items-center gap-3 animate-fade-up" style="--i:4; animation-delay:.45s">
      <a href={localizePath("pricing", lang)} class="btn-primary group relative">
        <span class="absolute -inset-0.5 -z-10 rounded-lg bg-gradient-to-r from-brand-500 to-brand-700 opacity-0 blur-md transition-opacity duration-300 group-hover:opacity-50"></span>
        {t("hero.cta-primary")}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="transition-transform duration-200 group-hover:translate-x-0.5">
          <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <a href={lang === "el" ? "/#features" : "/en/#features"} data-nav-anchor="features" class="btn-secondary group">
        <span class="flex items-center justify-center h-5 w-5 rounded-full bg-brand-50 text-brand-700 group-hover:bg-brand-100 transition-colors">
          <svg width="9" height="9" viewBox="0 0 14 14" fill="none">
            <path d="M3 1.5v11l9-5.5z" fill="currentColor" />
          </svg>
        </span>
        {t("hero.cta-secondary")}
      </a>
    </div>

    <p class="mt-5 text-[13px] text-gray-500 text-center animate-fade-up" style="--i:5; animation-delay:.55s">
      {t("hero.note")}
    </p>

    <!-- Dashboard with glow -->
    <div class="mt-16 md:mt-20 relative max-w-[1080px] mx-auto animate-fade-up" style="animation-delay:.5s">
      <!-- Glow halo behind dashboard -->
      <div class="absolute -inset-8 -z-10 bg-aurora opacity-60 blur-3xl" aria-hidden="true"></div>

      <!-- Floating badges -->
      <div class="absolute -top-5 -left-3 z-20 hidden md:block animate-subtle-float">
        <div class="inline-flex items-center gap-2 rounded-xl bg-ink text-white px-3.5 py-2.5 shadow-figure">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-peach-400 animate-pulse-ring"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-peach-500"></span>
          </span>
          <span class="text-[12px] font-semibold tracking-tight">
            {lang === "el" ? "AI παράγει σε 2 δευτ." : "AI generates in 2s"}
          </span>
        </div>
      </div>

      <div class="absolute -top-3 -right-2 z-20 hidden md:flex flex-col items-end" style="animation: float 8s ease-in-out infinite reverse;">
        <div class="rounded-xl bg-white border border-gray-200 px-3.5 py-2 shadow-card">
          <div class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <circle cx="7" cy="7" r="6" stroke="#0AA6A9" stroke-width="1.4"/>
              <path d="M4 7l2 2 4-4" stroke="#0AA6A9" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-[12px] font-semibold text-gray-700">GDPR · EU-hosted</span>
          </div>
        </div>
      </div>

      <div class="absolute top-1/2 -right-8 z-20 hidden lg:block" style="animation: float 9s ease-in-out infinite;">
        <div class="rounded-xl bg-peach-50 border border-peach-200 px-3.5 py-2.5 shadow-card">
          <div class="flex items-center gap-2.5">
            <div class="flex -space-x-1.5">
              <div class="h-6 w-6 rounded-full bg-brand-500 border-2 border-peach-50"></div>
              <div class="h-6 w-6 rounded-full bg-peach-500 border-2 border-peach-50"></div>
              <div class="h-6 w-6 rounded-full bg-brand-900 border-2 border-peach-50"></div>
            </div>
            <span class="text-[11px] font-semibold text-cream-800 leading-tight">
              {lang === "el" ? "Macros εντός" : "Macros on"}<br/>{lang === "el" ? "στόχου" : "target"}
            </span>
          </div>
        </div>
      </div>

      <!-- Dashboard container with browser chrome -->
      <div class="relative rounded-2xl bg-white border border-gray-200 overflow-hidden glow-teal">
        <!-- Browser bar -->
        <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-100 bg-gray-50">
          <div class="flex items-center gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-gray-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-gray-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-gray-300"></span>
          </div>
          <div class="ml-4 flex-1 max-w-xs mx-auto">
            <div class="rounded-md bg-white border border-gray-200 px-3 py-1 text-center flex items-center justify-center gap-1.5">
              <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><path d="M3 4.5V3a2 2 0 014 0v1.5M2.5 4.5h5v3.5h-5z" stroke="#0AA6A9" stroke-width="1"/></svg>
              <span class="text-[11px] text-gray-500 font-medium">nutriq.gr/clients/maria</span>
            </div>
          </div>
          <span class="w-9"></span>
        </div>

        <!-- Dashboard body -->
        <div class="grid grid-cols-12 min-h-[480px]">
          <!-- Sidebar -->
          <aside class="col-span-3 md:col-span-2 bg-brand-900 text-white p-3 md:p-4 flex flex-col gap-1">
            <div class="hidden md:flex items-center px-2 py-3">
              <img src="/nutriq-logo.svg" alt="" class="h-6 w-auto brightness-0 invert"/>
            </div>
            {[
              { i: "M3 12l9-7 9 7v9a2 2 0 01-2 2h-4v-7h-6v7H5a2 2 0 01-2-2v-9z", label: "Dashboard", active: false },
              { i: "M9 7a3 3 0 116 0 3 3 0 01-6 0zM3 21a7 7 0 0118 0", label: "Clients", active: true },
              { i: "M4 4h16v4H4zM4 12h16v4H4zM4 20h16v-4H4z", label: "Meal plans", active: false },
              { i: "M4 19h16M4 12h16M4 5h16", label: "Recipes", active: false },
              { i: "M12 6v6l4 2", label: "Sessions", active: false, circle: true },
              { i: "M3 7h18M3 12h18M3 17h12", label: "Reports", active: false },
            ].map((item) => (
              <a class={`flex items-center gap-2.5 rounded-md px-2 py-2 text-[12px] font-medium transition-colors ${item.active ? "bg-white/15 text-white" : "text-white/60 hover:bg-white/5 hover:text-white/80"}`}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  {item.circle && <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>}
                  <path d={item.i} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
                <span class="hidden md:inline">{item.label}</span>
              </a>
            ))}

            <div class="mt-auto hidden md:block">
              <div class="rounded-lg bg-white/5 border border-white/10 p-3">
                <p class="text-[10px] font-semibold uppercase tracking-wider text-peach-300">AI Credits</p>
                <p class="mt-1 text-[18px] font-bold tabular-nums">87 <span class="text-[11px] text-white/50 font-medium">/ 120</span></p>
                <div class="mt-2 h-1 bg-white/10 rounded-full overflow-hidden">
                  <div class="h-full bg-peach-400 rounded-full" style="width: 72%"></div>
                </div>
              </div>
            </div>
          </aside>

          <!-- Main panel -->
          <div class="col-span-6 md:col-span-7 p-5 md:p-6 border-r border-gray-100">
            <!-- Client header -->
            <div class="flex items-center gap-3">
              <div class="h-11 w-11 rounded-full bg-gradient-to-br from-brand-400 to-brand-700 flex items-center justify-center text-white text-lg font-semibold">
                Μ
              </div>
              <div>
                <p class="text-[15px] font-semibold text-ink">{lang === "el" ? "Μαρία Π." : "Maria P."}</p>
                <p class="text-[12px] text-gray-500">{lang === "el" ? "32 ετών · Στόχος: −5kg σε 3 μήνες" : "32 yrs · Goal: −5kg in 3 months"}</p>
              </div>
              <span class="ml-auto inline-flex items-center gap-1 text-[11px] font-semibold text-brand-700 bg-brand-50 px-2 py-0.5 rounded-full border border-brand-200/60">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-500 animate-pulse"></span>
                {lang === "el" ? "Ενεργό" : "Active"}
              </span>
            </div>

            <!-- Tabs -->
            <div class="mt-5 flex items-center gap-4 border-b border-gray-100 -mx-1">
              {[lang === "el" ? "Επισκόπηση" : "Overview", lang === "el" ? "Πλάνο" : "Plan", lang === "el" ? "Μετρήσεις" : "Metrics", lang === "el" ? "Σημειώσεις" : "Notes"].map((tab, i) => (
                <button class={`px-1 pb-2 text-[12px] font-semibold border-b-2 ${i === 1 ? "text-brand-900 border-brand-900" : "text-gray-500 border-transparent"}`}>{tab}</button>
              ))}
            </div>

            <!-- Plan title row -->
            <div class="mt-5 flex items-center justify-between">
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-brand-700">{lang === "el" ? "Εβδομάδα 12" : "Week 12"}</p>
                <h3 class="mt-1 text-[16px] font-bold tracking-[-0.02em] text-ink">{lang === "el" ? "Μεσογειακή · 1850 kcal" : "Mediterranean · 1850 kcal"}</h3>
              </div>
              <button class="inline-flex items-center gap-1.5 rounded-md bg-gradient-to-r from-peach-100 to-peach-50 border border-peach-300/60 px-3 py-1.5 text-[11px] font-semibold text-peach-700 hover:from-peach-200 hover:to-peach-100 transition-colors">
                <svg width="11" height="11" viewBox="0 0 16 16" fill="none">
                  <path d="M8 1l1.7 4.6L14 7l-4.3 1.4L8 13l-1.7-4.6L2 7l4.3-1.4z" fill="currentColor"/>
                </svg>
                {lang === "el" ? "Παραγωγή με AI" : "Generate with AI"}
              </button>
            </div>

            <!-- Meal rows with stagger reveal -->
            <div class="mt-4 space-y-2" id="meal-list">
              {[
                { time: lang === "el" ? "Πρωινό · 08:00" : "Breakfast · 08:00", title: lang === "el" ? "Βρώμη με μπλούμπερις & καρύδια" : "Oats with blueberries & walnuts", kcal: 320, color: "from-peach-100 to-peach-200" },
                { time: lang === "el" ? "Δεκατιανό · 11:00" : "Snack · 11:00", title: lang === "el" ? "Γιαούρτι ελληνικό 2%" : "Greek yogurt 2%", kcal: 180, color: "from-brand-50 to-brand-100" },
                { time: lang === "el" ? "Μεσημεριανό · 14:00" : "Lunch · 14:00", title: lang === "el" ? "Bowl κινόα με σολομό & αβοκάντο" : "Quinoa bowl with salmon & avocado", kcal: 540, color: "from-cream-200 to-cream-300" },
                { time: lang === "el" ? "Απογευματινό · 17:00" : "Snack · 17:00", title: lang === "el" ? "Καρύδια & μήλο" : "Walnuts & apple", kcal: 210, color: "from-peach-100 to-peach-200" },
                { time: lang === "el" ? "Βραδινό · 20:00" : "Dinner · 20:00", title: lang === "el" ? "Ψητό κοτόπουλο με γλυκοπατάτα" : "Roast chicken with sweet potato", kcal: 600, color: "from-brand-100 to-brand-200" },
              ].map((meal, i) => (
                <div class="meal-row flex items-center gap-3 rounded-lg p-2.5 hover:bg-gray-50 transition-colors" style={`animation-delay: ${0.8 + i * 0.1}s`}>
                  <div class={`h-9 w-9 rounded-md bg-gradient-to-br ${meal.color} flex-shrink-0`}></div>
                  <div class="flex-1 min-w-0">
                    <p class="text-[10px] text-gray-500 font-medium uppercase tracking-wider">{meal.time}</p>
                    <p class="text-[13px] font-medium text-ink truncate">{meal.title}</p>
                  </div>
                  <p class="text-[13px] font-semibold text-gray-700 tabular-nums">{meal.kcal} <span class="text-[10px] text-gray-400 font-medium">kcal</span></p>
                </div>
              ))}
            </div>
          </div>

          <!-- Right rail: live metrics -->
          <aside class="col-span-3 p-5 md:p-6 bg-gray-50/40">
            <div class="flex items-center justify-between">
              <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-gray-500">{lang === "el" ? "Πρόοδος" : "Progress"}</p>
              <span class="text-[10px] text-brand-700 font-semibold inline-flex items-center gap-1">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-500 animate-pulse"></span>
                Live
              </span>
            </div>

            <!-- Weight chart -->
            <div class="mt-3 rounded-lg bg-white border border-gray-100 p-3">
              <div class="flex items-center justify-between">
                <span class="text-[11px] text-gray-500 font-medium">{lang === "el" ? "Βάρος" : "Weight"}</span>
                <span class="text-[10px] font-semibold text-brand-700 tabular-nums">−1.8kg</span>
              </div>
              <p class="mt-1 text-[22px] font-bold text-ink tabular-nums">76.4<span class="text-[11px] text-gray-400 ml-0.5 font-medium">kg</span></p>
              <svg viewBox="0 0 100 30" class="mt-2 w-full h-7" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="sparkGrad" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#0AA6A9"/>
                    <stop offset="100%" stop-color="#0AA6A9" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path class="sparkline" d="M0,8 L15,12 L30,10 L45,15 L60,18 L75,22 L100,25" stroke="#0AA6A9" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M0,8 L15,12 L30,10 L45,15 L60,18 L75,22 L100,25 L100,30 L0,30 Z" fill="url(#sparkGrad)" opacity="0.18"/>
                <circle cx="100" cy="25" r="2.5" fill="#0AA6A9">
                  <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
                </circle>
              </svg>
            </div>

            <!-- Body comp with animated bars -->
            <div class="mt-3 rounded-lg bg-white border border-gray-100 p-3">
              <span class="text-[11px] text-gray-500 font-medium">{lang === "el" ? "Σύσταση σώματος" : "Body composition"}</span>
              <div class="mt-2 space-y-2">
                <div>
                  <div class="flex items-center justify-between text-[10px]">
                    <span class="text-gray-500">{lang === "el" ? "Λίπος" : "Fat"}</span>
                    <span class="font-semibold text-ink tabular-nums">27.3%</span>
                  </div>
                  <div class="mt-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="bar h-full bg-peach-400 rounded-full" style="--w: 27%"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between text-[10px]">
                    <span class="text-gray-500">{lang === "el" ? "Μυϊκή μάζα" : "Muscle"}</span>
                    <span class="font-semibold text-ink tabular-nums">38.2%</span>
                  </div>
                  <div class="mt-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="bar h-full bg-brand-500 rounded-full" style="--w: 38%"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between text-[10px]">
                    <span class="text-gray-500">{lang === "el" ? "Νερό" : "Water"}</span>
                    <span class="font-semibold text-ink tabular-nums">52.1%</span>
                  </div>
                  <div class="mt-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="bar h-full bg-brand-300 rounded-full" style="--w: 52%"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Today's macros -->
            <div class="mt-3 rounded-lg bg-gradient-to-br from-brand-900 to-brand-700 text-white p-3">
              <span class="text-[10px] font-semibold uppercase tracking-wider text-peach-300">{lang === "el" ? "Macros σήμερα" : "Today's macros"}</span>
              <div class="mt-2 flex items-baseline gap-1">
                <span class="text-[22px] font-bold tabular-nums" id="kcal-counter">1,850</span>
                <span class="text-[11px] text-white/55">/ 1,850</span>
              </div>
              <div class="mt-2 h-1.5 bg-white/15 rounded-full overflow-hidden">
                <div class="bar h-full bg-peach-400 rounded-full" style="--w: 100%"></div>
              </div>
              <p class="mt-2 text-[10px] text-peach-300 font-semibold inline-flex items-center gap-1">
                <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><path d="M2 5l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                100% {lang === "el" ? "στόχου" : "of goal"}
              </p>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Stagger meal rows */
  .meal-row {
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Animated bars fill */
  .bar {
    width: 0;
    animation: barFill 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
  }
  @keyframes barFill {
    from { width: 0; }
    to { width: var(--w); }
  }

  /* Sparkline draw-on */
  .sparkline {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: drawLine 1.6s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
  }
  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Live counter — increments slowly, hand-wavy "live" feel
  const counter = document.getElementById("live-counter");
  if (counter) {
    let val = 2341;
    setInterval(() => {
      val += Math.floor(Math.random() * 3) + 1;
      counter.textContent = val.toLocaleString("en-US");
    }, 4200);
  }
</script>
