---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const values = [
  { t: t("about.v1.t"), b: t("about.v1.b"), icon: "M3 8l5 5 9-10" },
  { t: t("about.v2.t"), b: t("about.v2.b"), icon: "M10 2L3 6v6c0 4 3 7 7 8 4-1 7-4 7-8V6l-7-4z" },
  { t: t("about.v3.t"), b: t("about.v3.b"), icon: "M4 10l4 4 8-10" },
  { t: t("about.v4.t"), b: t("about.v4.b"), icon: "M8 9c1.7 0 3-1.3 3-3S9.7 3 8 3 5 4.3 5 6s1.3 3 3 3zm6 1c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zM2 16c0-2.7 2.7-5 6-5s6 2.3 6 5M14 14c1.7 0 4 1 4 3" },
];
---

<section id="about" class="section bg-white scroll-mt-header">
  <div class="container-x">
    <!-- Hero block -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5">
        <p class="overline">{t("about.eyebrow")}</p>
        <h2 class="mt-5 text-display-md text-ink text-balance">
          {t("about.title")}
        </h2>

        <!-- Founding year chip -->
        <div class="mt-8 inline-flex items-center gap-3 rounded-xl bg-cream-100 border border-gray-200 px-4 py-3">
          <div class="flex items-center justify-center h-9 w-9 rounded-lg bg-brand-900 text-white">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="3" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 7h12M5 1v4M11 1v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-wider text-gray-500">{lang === "el" ? "Έτος ίδρυσης" : "Founded"}</p>
            <p class="text-[15px] font-bold tracking-tight text-ink tabular-nums">2026 · {lang === "el" ? "Αθήνα" : "Athens"}</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-6 lg:col-start-7 space-y-5">
        <p class="text-[18px] leading-[1.6] text-ink text-pretty font-medium">
          {t("about.subtitle")}
        </p>
        <p class="text-[15px] leading-[1.7] text-gray-600 text-pretty">
          {t("about.story-1")}
        </p>
        <p class="text-[15px] leading-[1.7] text-gray-600 text-pretty">
          {t("about.story-2")}
        </p>
      </div>
    </div>

    <!-- Team partnership visual -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Devs side -->
      <div class="rounded-2xl bg-gradient-to-br from-brand-900 to-brand-700 text-white p-7 md:p-8 overflow-hidden relative">
        <div class="relative">
          <div class="flex items-center gap-2.5">
            <div class="flex items-center justify-center h-10 w-10 rounded-lg bg-white/10 backdrop-blur-sm border border-white/15">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M8 6l-5 6 5 6M16 6l5 6-5 6M14 4l-4 16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="text-[12px] font-semibold uppercase tracking-[0.14em] text-peach-300">{lang === "el" ? "Engineers" : "Engineers"}</span>
          </div>
          <p class="mt-5 text-[20px] font-bold tracking-[-0.02em] leading-tight">
            {lang === "el" ? "Φτιάχνουμε software σχεδιασμένο για επαγγελματίες." : "We build software designed for professionals."}
          </p>
          <p class="mt-3 text-[14px] leading-relaxed text-white/75">
            {lang === "el"
              ? "Backend σε Java + Spring Boot. Frontend σε Next.js. AI σε ειδικά εκπαιδευμένα μοντέλα. EU-hosted infrastructure."
              : "Backend in Java + Spring Boot. Frontend in Next.js. AI in custom-trained models. EU-hosted infrastructure."}
          </p>
        </div>

        <!-- Decorative grid -->
        <div class="absolute -bottom-8 -right-8 h-32 w-32 opacity-20" aria-hidden="true">
          <svg viewBox="0 0 100 100" class="w-full h-full text-peach-300">
            <pattern id="dotgrid" x="0" y="0" width="10" height="10" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r="1" fill="currentColor"/>
            </pattern>
            <rect width="100" height="100" fill="url(#dotgrid)"/>
          </svg>
        </div>
      </div>

      <!-- Nutritionists side -->
      <div class="rounded-2xl bg-gradient-to-br from-peach-100 to-cream-200 text-ink p-7 md:p-8 overflow-hidden relative border border-peach-200/50">
        <div class="relative">
          <div class="flex items-center gap-2.5">
            <div class="flex items-center justify-center h-10 w-10 rounded-lg bg-white border border-peach-200">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 21s-7-5-7-11a5 5 0 017-4 5 5 0 017 4c0 6-7 11-7 11z" stroke="#E37636" stroke-width="1.7" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="text-[12px] font-semibold uppercase tracking-[0.14em] text-peach-700">{lang === "el" ? "Διαιτολόγοι" : "Dietitians"}</span>
          </div>
          <p class="mt-5 text-[20px] font-bold tracking-[-0.02em] leading-tight text-ink">
            {lang === "el" ? "Καθοδηγούμε το προϊόν από την πρώτη γραμμή." : "We guide the product from the front line."}
          </p>
          <p class="mt-3 text-[14px] leading-relaxed text-gray-700">
            {lang === "el"
              ? "Κλινικοί διαιτολόγοι με χρόνια εμπειρίας. Καταλαβαίνουμε ποιο feature θα δουλέψει — και ποιο είναι θόρυβος. Κάθε σχεδιαστική απόφαση περνά από εμάς."
              : "Clinical dietitians with years of experience. We understand which feature will work — and which is noise. Every design decision goes through us."}
          </p>
        </div>
      </div>
    </div>

    <!-- Values -->
    <div class="mt-20">
      <p class="overline">{t("about.values-eye")}</p>
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {values.map((v, i) => (
          <div class="rounded-xl bg-cream-100 border border-gray-200 p-6">
            <div class="flex items-center justify-center h-10 w-10 rounded-lg bg-white border border-gray-200 text-brand-700">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                <path d={v.icon} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="mt-4 text-[15px] font-bold tracking-[-0.01em] text-ink">{v.t}</h3>
            <p class="mt-2 text-[13px] leading-relaxed text-gray-600">{v.b}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
