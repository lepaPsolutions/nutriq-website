---
import { getLangFromUrl, useTranslations, localizePath } from "../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="section bg-white">
  <div class="container-x">
    <div class="relative rounded-3xl bg-brand-900 overflow-hidden">
      <!-- Subtle gradient overlay -->
      <div class="absolute inset-0" aria-hidden="true">
        <div class="absolute -top-20 -right-20 h-[400px] w-[400px] rounded-full bg-peach-400/10 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 h-[400px] w-[400px] rounded-full bg-brand-500/15 blur-3xl"></div>
      </div>

      <!-- Echo of heart logo -->
      <img
        src="/nutriq-mark.svg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute -bottom-12 -right-8 h-72 w-72 opacity-[0.06] rotate-12 brightness-0 invert"
      />

      <div class="relative px-8 md:px-16 lg:px-24 py-16 md:py-20 text-center">
        <h2 class="text-display-lg text-white text-balance max-w-3xl mx-auto">
          {t("cta.title")}
        </h2>
        <p class="mt-6 max-w-xl mx-auto text-[18px] leading-[1.55] text-white/75 text-pretty">
          {t("cta.subtitle")}
        </p>
        <div class="mt-10 flex flex-wrap justify-center items-center gap-3">
          <a href={localizePath("pricing", lang)} class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-ink text-[15px] font-semibold tracking-[-0.005em] transition-all hover:bg-cream-100 active:scale-[0.98] shadow-lg">
            {t("cta.button")}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a href={localizePath("contact", lang)} class="inline-flex items-center gap-1.5 text-[15px] font-semibold text-white/85 hover:text-white transition-colors px-4 py-3">
            {lang === "el" ? "Μίλα μαζί μας" : "Talk to us"}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
