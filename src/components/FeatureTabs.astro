<script>
  const btns = document.querySelectorAll<HTMLButtonElement>("[data-feature-tab]");
  const panels = document.querySelectorAll<HTMLElement>("[data-feature-panel]");

  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.featureTab;
      btns.forEach((b) => b.dataset.active = String(b.dataset.featureTab === target));
      panels.forEach((p) => {
        if (p.dataset.featurePanel === target) {
          p.hidden = false;
        } else {
          p.hidden = true;
        }
      });
      // Smooth scroll into view on mobile
      if (window.innerWidth < 1024) {
        const panel = document.querySelector<HTMLElement>(`[data-feature-panel="${target}"]`);
        panel?.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  });
</script>
