---
import { localizePath, getLangFromUrl, useTranslations } from "../i18n/utils";

interface Bullet {
  title: string;
  body: string;
}

interface Props {
  eyebrow: string;
  title: string;
  sub: string;
  bullets: Bullet[];
  closingHeading: string;
  closingBody: string;
}

const { eyebrow, title, sub, bullets, closingHeading, closingBody } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative pt-20 md:pt-24 pb-16 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-aurora opacity-80" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 bg-grid opacity-30" aria-hidden="true"></div>
  <div class="container-x">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/80 backdrop-blur-md border border-gray-200 px-4 py-1.5 shadow-xs">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        <span class="text-[12px] font-semibold tracking-[0.04em] uppercase text-gray-700">{eyebrow}</span>
      </div>
      <h1 class="mt-6 text-display-lg text-ink text-balance">{title}</h1>
      <p class="mt-7 text-[18px] leading-[1.55] text-gray-600 text-pretty">{sub}</p>
      <div class="mt-10">
        <a href={localizePath("pricing", lang)} class="btn-primary">
          {t("hero.cta-primary")}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="section bg-cream-200/40">
  <div class="container-x">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {bullets.map((b, i) => (
        <div class="rounded-2xl bg-cream-50 p-7 border border-ink/8 shadow-card">
          <span class="font-display text-3xl text-brand-700/60">0{i + 1}</span>
          <h3 class="mt-4 font-display text-2xl text-ink">{b.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-ink/65">{b.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container-x">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-display text-display-md text-ink text-balance">{closingHeading}</h2>
      <p class="mt-6 text-[17px] leading-relaxed text-ink/70 text-pretty">{closingBody}</p>
    </div>
  </div>
</section>
